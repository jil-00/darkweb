APP_NAME=Threat Intelligence API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

JWT_SECRET_KEY=replace_with_secure_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=threat_intel
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
ALERT_RISK_THRESHOLD=60

VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
IPINFO_TOKEN=

EXTERNAL_API_TIMEOUT_SECONDS=15
EXTERNAL_API_MAX_RETRIES=3
EXTERNAL_API_BACKOFF_SECONDS=0.75

RISK_WEIGHT_BREACH_DB=0.9
RISK_WEIGHT_FORUM=0.6
RISK_WEIGHT_PASTE=0.7
RISK_SENSITIVITY_PASSWORD=1.0
RISK_SENSITIVITY_EMAIL=0.7
RISK_SENSITIVITY_USERNAME=0.5
RISK_SENSITIVITY_DOMAIN=0.6